    <item>
      <title></title>
      <link>http://localhost:1313/publications/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/publications/</guid>
      <description>&lt;!DOCTYPE html&gt;
&lt;html lang=&#34;en&#34;&gt;
&lt;head&gt;
  &lt;meta charset=&#34;UTF-8&#34; /&gt;
  &lt;meta name=&#34;viewport&#34; content=&#34;width=device-width, initial-scale=1.0&#34; /&gt;
  &lt;title&gt;Publications&lt;/title&gt;
  &lt;link rel=&#34;preconnect&#34; href=&#34;https://fonts.googleapis.com&#34; /&gt;
  &lt;link rel=&#34;preconnect&#34; href=&#34;https://fonts.gstatic.com&#34; crossorigin /&gt;
  &lt;link href=&#34;https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&amp;family=DM+Mono:wght@400;500&amp;family=Lato:wght@300;400;700&amp;display=swap&#34; rel=&#34;stylesheet&#34; /&gt;
  &lt;style&gt;

    .main {
      max-width: 100% !important;
      padding: 0 3rem !important;
    }

    :root {
    --bg: #ffffff;
    --surface: #f5f5f5;
    --border: rgba(0,0,0,0.1);
    --border-hover: rgba(0,0,0,0.25);
    --text-primary: #1a1a1a;
    --text-secondary: #555550;
    --text-muted: #999990;
    --accent: #8b6914;
    --accent-dim: rgba(139,105,20,0.08);
    --tag-bg: rgba(139,105,20,0.08);
    --tag-color: #7a5c10;
    --link: #1a5fa8;
   }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #ffffff;
      color: var(--text-primary);
      font-family: &#39;Nunito&#39;, sans-serif !important;
      font-weight: 300 !important;
      font-size: 16px !important;
      line-height: 1.7 !important;
      min-height: 100vh;
    }

    p, li, span, a {
      font-size: 16px !important;
    }

    .paper-abstract {
      font-size: 16px !important;
    }

    .paper-authors {
      font-size: 14px !important;
    }

    .paper-title {
      font-size: 1.4rem !important;
    }

    /* ── NAV ── */
    nav {
      border-bottom: 1px solid var(--border);
      padding: 0 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 56px;
    }

    .nav-brand {
      font-family: &#39;DM Serif Display&#39;, serif;
      font-size: 1.15rem;
      color: var(--text-primary);
      text-decoration: none;
      letter-spacing: 0.01em;
    }

    .nav-links {
      display: flex;
      gap: 1.8rem;
      list-style: none;
    }

    .nav-links a {
      font-size: 0.82rem;
      font-weight: 400;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text-secondary);
      text-decoration: none;
      transition: color 0.2s;
    }

    .nav-links a:hover,
    .nav-links a.active { color: var(--accent); }

    /* ── MAIN LAYOUT ── */
    main {
      max-width: 780px;
      margin: 0 auto;
      padding: 4rem 2rem 6rem;
    }

    /* ── PAGE HEADER ── */
    .page-header {
      margin-bottom: 3.5rem;
      border-bottom: 1px solid var(--border);
      padding-bottom: 2rem;
    }

    .page-header h1 {
      font-family: &#39;DM Serif Display&#39;, serif;
      font-size: 2.6rem;
      font-weight: 400;
      line-height: 1.15;
      color: var(--text-primary);
      margin-bottom: 0.75rem;
    }

    .page-header p {
      font-size: 0.95rem;
      color: var(--text-secondary);
      max-width: 520px;
    }

    .page-header p a {
      color: var(--link);
      text-decoration: none;
      border-bottom: 1px solid transparent;
      transition: border-color 0.2s;
    }

    .page-header p a:hover { border-color: var(--link); }

    /* ── FILTER BAR ── */
    .filter-bar {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin-bottom: 2.5rem;
    }

    .filter-btn {
      font-size: 0.75rem;
      font-family: &#39;DM Mono&#39;, monospace;
      letter-spacing: 0.05em;
      padding: 4px 14px;
      border: 1px solid var(--border);
      border-radius: 2px;
      background: transparent;
      color: var(--text-muted);
      cursor: pointer;
      transition: all 0.18s;
    }

    .filter-btn:hover { border-color: var(--border-hover); color: var(--text-primary); }
    .filter-btn.active { border-color: var(--accent); color: var(--accent); background: var(--accent-dim); }

    /* ── PAPER CARD ── */
    .paper-list { display: flex; flex-direction: column; gap: 0; }

    .paper-card {
      padding: 1.75rem 0;
      border-bottom: 1px solid var(--border);
      display: grid;
      grid-template-columns: 48px 1fr;
      gap: 0 1.25rem;
      transition: background 0.2s;
    }

    .paper-card:first-child { border-top: 1px solid var(--border); }

    .paper-year {
      font-family: &#39;DM Mono&#39;, monospace;
      font-size: 0.72rem;
      color: var(--text-muted);
      padding-top: 4px;
      letter-spacing: 0.05em;
      text-align: right;
    }

    /* .paper-body {} */

    .paper-venue-row {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 0.35rem;
      flex-wrap: wrap;
    }

    .venue-tag {
      font-size: 0.7rem;
      font-family: &#39;DM Mono&#39;, monospace;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 2px 8px;
      background: var(--tag-bg);
      color: var(--tag-color);
      border-radius: 2px;
    }

    .paper-title {
      font-family: &#39;DM Serif Display&#39;, serif;
      font-size: 1.15rem;
      font-weight: 400;
      color: var(--text-primary);
      line-height: 1.3;
      margin-bottom: 0.5rem;
      text-decoration: none;
      display: block;
      transition: color 0.18s;
    }

    .paper-title:hover { color: var(--accent); }

    .paper-authors {
      font-size: 0.82rem;
      color: var(--text-secondary);
      margin-bottom: 0.6rem;
      font-weight: 400;
    }

    .paper-authors strong {
      color: var(--text-primary);
      font-weight: 700;
    }

    .paper-abstract {
      font-size: 0.875rem;
      color: var(--text-secondary);
      line-height: 1.65;
      margin-bottom: 0.9rem;
      max-width: 600px;
    }

    .paper-links {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .paper-link {
      font-size: 0.75rem;
      font-family: &#39;DM Mono&#39;, monospace;
      letter-spacing: 0.04em;
      color: var(--text-muted);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 4px;
      border-bottom: 1px solid transparent;
      padding-bottom: 1px;
      transition: color 0.18s, border-color 0.18s;
    }

    .paper-link:hover { color: var(--link); border-color: var(--link); }

    .paper-link svg {
      width: 11px; height: 11px;
      stroke: currentColor;
      fill: none;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
      flex-shrink: 0;
    }

    /* ── FOOTER ── */
    footer {
      border-top: 1px solid var(--border);
      text-align: center;
      padding: 2rem;
      font-size: 0.78rem;
      color: var(--text-muted);
    }

    footer a { color: var(--text-muted); text-decoration: none; }
    footer a:hover { color: var(--text-secondary); }

    @media (max-width: 540px) {
      nav { padding: 0 1rem; }
      .nav-links { gap: 1rem; }
      main { padding: 2.5rem 1rem 4rem; }
      .page-header h1 { font-size: 2rem; }
      .paper-card { grid-template-columns: 36px 1fr; gap: 0 0.75rem; }
    }
  &lt;/style&gt;
&lt;/head&gt;
